<Project>
  <PropertyGroup>
    <EmbeddedSassEnabled Condition="'$(EmbeddedSassEnabled)' == ''">true</EmbeddedSassEnabled>
    <EmbeddedSassOutputStyle Condition="'$(EmbeddedSassOutputStyle)' == ''">Auto</EmbeddedSassOutputStyle>
    <EmbeddedSassGenerateSourceMap Condition="'$(EmbeddedSassGenerateSourceMap)' == ''">Auto</EmbeddedSassGenerateSourceMap>
    <EmbeddedSassIncludeSourcesInSourceMap Condition="'$(EmbeddedSassIncludeSourcesInSourceMap)' == ''">true</EmbeddedSassIncludeSourcesInSourceMap>
    <EmbeddedSassQuietDependencies Condition="'$(EmbeddedSassQuietDependencies)' == ''">false</EmbeddedSassQuietDependencies>
    <EmbeddedSassSilencedDeprecations Condition="'$(EmbeddedSassSilencedDeprecations)' == ''"></EmbeddedSassSilencedDeprecations>
    <EmbeddedSassTasksAssembly Condition="'$(EmbeddedSassTasksAssembly)' == ''">$(MSBuildThisFileDirectory)..\tasks\net10.0\EmbeddedSass.Net.MsBuild.dll</EmbeddedSassTasksAssembly>
    <EmbeddedSassGeneratedFilesManifest Condition="'$(EmbeddedSassGeneratedFilesManifest)' == ''">$(BaseIntermediateOutputPath)$(Configuration)/EmbeddedSass.generated.txt</EmbeddedSassGeneratedFilesManifest>
    <EmbeddedSassCacheFile Condition="'$(EmbeddedSassCacheFile)' == ''">$(BaseIntermediateOutputPath)$(Configuration)/EmbeddedSass.cache.json</EmbeddedSassCacheFile>
  </PropertyGroup>
</Project>
